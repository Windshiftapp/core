# Windshift Production Configuration
# Copy this file to .env and configure for your environment

# Required: Base URL where windshift will be accessed
# Used to configure CORS allowed hosts
# Examples:
#   https://windshift.example.com
#   https://windshift.example.com:8443
#   http://localhost:8080
BASE_URL=https://windshift.example.com

# Optional: External port (default: 8080)
PORT=8080

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info

# Secret Key Configuration
# ---------------------
# Required: Secret key for encrypting credentials (SSO, Jira, SCM integrations)
# Generate with: openssl rand -hex 32
# SSO_SECRET=your-secure-random-key-here

# Database Configuration
# ---------------------
# DB_TYPE: sqlite (default) or postgres
DB_TYPE=sqlite

# PostgreSQL settings (only used when DB_TYPE=postgres)
# Uncomment and configure these when using PostgreSQL:
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_USER=windshift
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=windshift

# SSH TUI Configuration (optional)
# ---------------------
# Set SSH_ENABLED=true to enable SSH TUI access
# Also uncomment the SSH port mapping in docker-compose.prod.yml
SSH_ENABLED=false
SSH_PORT=23234
SSH_HOST=0.0.0.0

# Reverse Proxy Configuration
# ---------------------
# Enable if running behind a reverse proxy (trusts X-Forwarded-Proto from private IPs)
# WARNING: Only enable when behind a reverse proxy that terminates TLS
USE_PROXY=false

# Additional proxy IPs to trust beyond private ranges (comma-separated)
# ADDITIONAL_PROXIES=10.0.0.1,172.16.0.1
