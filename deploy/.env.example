# Windshift Environment Configuration
# Copy this file to .env and configure your settings
# Run ./init.sh to automatically generate SSO_SECRET

# =============================================================================
# Required Settings
# =============================================================================

# Domain where Windshift will be accessible (without protocol)
DOMAIN=windshift.example.com

# Host port to expose (default: 8080)
# PORT=8080

# Secret key for SSO authentication (auto-generated by init.sh)
# Generate manually with: openssl rand -hex 32
SSO_SECRET=

# =============================================================================
# PostgreSQL Settings (uncomment when using PostgreSQL instead of SQLite)
# =============================================================================

# POSTGRES_PASSWORD=your-secure-password-here

# =============================================================================
# Traefik Settings (uncomment when using built-in Traefik reverse proxy)
# =============================================================================

# Email for Let's Encrypt certificate notifications
# LETSENCRYPT_EMAIL=admin@example.com
